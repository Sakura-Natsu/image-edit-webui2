# OpenAI API Key（可选；前端设置页可覆盖）
OPENAI_API_KEY=

# OpenAI 兼容 Base URL（可选；默认 https://api.openai.com/v1）
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Supabase 云端存储（可选）────────────────────────────────────────────────
# 填写后将自动启用 Supabase 模式：历史元数据存入 Postgres，图片存入 Storage。
# 不填则继续使用本地 ./data/ 目录（适合本地开发）。
#
# 在 Supabase Dashboard → Project Settings → API 中获取：
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 本地历史 / 图片存储根目录（仅本地模式有效；默认为项目根下的 ./data）
# IMAGE_WEBUI_DATA_DIR=./data
